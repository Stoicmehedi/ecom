// MPoS — Retail POS + Inventory (single-store MVP)
// Schema: Phase-1 core. See BLUEPRINT.md for the full data model.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------
enum ContactType {
  CUSTOMER
  SUPPLIER
}

enum ProductType {
  SIMPLE
  VARIABLE
}

enum SaleChannel {
  REGULAR
  WHOLESALE
  ONLINE
}

enum DocStatus {
  PAID
  PARTIAL
  DUE
}

enum StockMovementType {
  PURCHASE
  SALE
  PURCHASE_RETURN
  SALE_RETURN
  ADJUSTMENT
}

enum AccountType {
  CASH
  BANK
}

enum PaymentDirection {
  IN
  OUT
}

enum DiscountType {
  AMOUNT
  PERCENT
}

// ---------- Org / Access ----------
model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users     User[]
  products  Product[]
  purchases Purchase[]
  sales     Sale[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions String[] // list of "module.action" keys
  createdAt   DateTime @default(now())

  users User[]
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  username     String   @unique
  email        String?  @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  roleId   Int?
  role     Role?   @relation(fields: [roleId], references: [id])
  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  salesSold Sale[]     @relation("SoldBy")
  heldSales HeldSale[] @relation("HeldBy")
}

// ---------- Catalog ----------
model Category {
  id        Int      @id @default(autoincrement())
  name      String
  level     Int      @default(1) // 1=category, 2=sub, 3=child
  createdAt DateTime @default(now())

  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]
}

model Brand {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

// ---------- Variant dimensions ----------

/// A named axis a product can vary along — Size, Fit, Material.
model AttributeCategory {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  createdAt  DateTime    @default(now())
  attributes Attribute[]
  products   Product[]
}

/// A value on that axis — 32, 34, Slim, Cotton.
model Attribute {
  id        Int      @id @default(autoincrement())
  name      String
  sortIndex Int      @default(0)
  createdAt DateTime @default(now())

  attributeCategoryId Int
  attributeCategory   AttributeCategory @relation(fields: [attributeCategoryId], references: [id], onDelete: Cascade)

  /// Which products offer this value (the picker on the product form).
  products Product[]
  /// Which generated variants carry it.
  variants ProductVariant[]

  @@unique([attributeCategoryId, name])
}

/// Colour is its own axis, crossed with the attribute to generate variants.
model Color {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  hex       String? // for a swatch; optional
  sortIndex Int      @default(0)
  createdAt DateTime @default(now())

  products Product[]
  variants ProductVariant[]
}

model Unit {
  id        Int       @id @default(autoincrement())
  name      String
  shortName String?
  products  Product[]
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  code        String? // a second identifier alongside the variants' SKUs
  description String?
  type        ProductType @default(SIMPLE)
  imageUrl    String?
  isActive    Boolean     @default(true)
  sortIndex   Int         @default(0)
  createdAt   DateTime    @default(now())

  /// Low-stock threshold for THIS product. Null falls back to the global default.
  alertQty Decimal? @db.Decimal(14, 3)
  /// A price floor. Checkout refuses to sell any variant below it (BLUEPRINT §12.7).
  minSalePrice Decimal? @db.Decimal(14, 2)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
  brandId    Int?
  brand      Brand?    @relation(fields: [brandId], references: [id])
  unitId     Int?
  unit       Unit?     @relation(fields: [unitId], references: [id])
  branchId   Int?
  branch     Branch?   @relation(fields: [branchId], references: [id])

  /// The axis this product varies along, and the values picked on it — kept so the
  /// variant grid can be regenerated on edit without re-picking everything.
  attributeCategoryId Int?
  attributeCategory   AttributeCategory? @relation(fields: [attributeCategoryId], references: [id])
  attributes          Attribute[]
  colors              Color[]

  variants ProductVariant[]
}

model ProductVariant {
  id                Int      @id @default(autoincrement())
  sku               String   @unique
  barcode           String?  @unique // auto EAN-13 (in-store `20` range), editable
  label             String? // e.g. "Red / L"
  attributes        Json? // { color: "Red", size: "L" }
  sortIndex         Int      @default(0)
  purchasePrice     Decimal  @default(0) @db.Decimal(14, 2) // weighted-average cost
  lastPurchasePrice Decimal? @db.Decimal(14, 2) // price on the most recent purchase
  sellingPrice      Decimal  @default(0) @db.Decimal(14, 2)
  stockQty          Decimal  @default(0) @db.Decimal(14, 3)
  createdAt         DateTime @default(now())

  /// Sell this many or more on one line and the price switches to wholesale.
  wholesalePrice Decimal? @db.Decimal(14, 2)
  wholesaleQty   Decimal? @db.Decimal(14, 3)

  /// A standing discount on this variant. Competes with the customer group's rate —
  /// the bigger of the two wins, they never stack (BLUEPRINT §12.7a).
  discountType  DiscountType @default(AMOUNT)
  discountValue Decimal      @default(0) @db.Decimal(14, 2)

  /// What this variant *is*, on each axis — set by the variant generator.
  attributeId Int?
  attribute   Attribute? @relation(fields: [attributeId], references: [id])
  colorId     Int?
  color       Color?     @relation(fields: [colorId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  purchaseItems       PurchaseItem[]
  saleItems           SaleItem[]
  stockMovements      StockMovement[]
  purchaseReturnItems PurchaseReturnItem[]
  saleReturnItems     SaleReturnItem[]

  @@index([productId])
}

// ---------- Contacts (customers & suppliers) ----------
model CustomerGroup {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  discount  Decimal  @default(0) @db.Decimal(5, 2) // default % off this customer's sales
  createdAt DateTime @default(now())

  customers Contact[]
}

model Contact {
  id             Int         @id @default(autoincrement())
  type           ContactType
  name           String
  businessName   String?
  phone          String?
  email          String?
  address        String?
  note           String?
  openingBalance Decimal     @default(0) @db.Decimal(14, 2)
  // For a supplier: + = we owe them (payable). For a customer: + = they owe us.
  dueBalance     Decimal     @default(0) @db.Decimal(14, 2)
  loyaltyPoints  Int         @default(0)
  isActive       Boolean     @default(true)
  isWalkIn       Boolean     @default(false) // the POS default customer; not deletable
  createdAt      DateTime    @default(now())

  customerGroupId Int?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id])

  purchases       Purchase[]
  sales           Sale[]
  payments        Payment[]
  purchaseReturns PurchaseReturn[]
  saleReturns     SaleReturn[]

  @@index([type])
}

// ---------- Purchasing ----------
model Purchase {
  id                Int          @id @default(autoincrement())
  purchaseNo        String       @unique // our own sequence, e.g. PUR-00001
  supplierInvoiceNo String? // the supplier's invoice number — may repeat
  date              DateTime     @default(now())
  dueDate           DateTime?
  reference         String?
  note              String?
  subtotal          Decimal      @default(0) @db.Decimal(14, 2)
  discountType      DiscountType @default(AMOUNT)
  discountValue     Decimal      @default(0) @db.Decimal(14, 2)
  discount          Decimal      @default(0) @db.Decimal(14, 2) // resolved amount
  total             Decimal      @default(0) @db.Decimal(14, 2)
  paid              Decimal      @default(0) @db.Decimal(14, 2)
  due               Decimal      @default(0) @db.Decimal(14, 2)
  status            DocStatus    @default(DUE)
  createdAt         DateTime     @default(now())

  supplierId Int?
  supplier   Contact? @relation(fields: [supplierId], references: [id])
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id])

  items    PurchaseItem[]
  payments Payment[]
  returns  PurchaseReturn[]
}

model PurchaseItem {
  id            Int     @id @default(autoincrement())
  qty           Decimal @db.Decimal(14, 3)
  purchasePrice Decimal @db.Decimal(14, 2)
  subtotal      Decimal @db.Decimal(14, 2)
  returnedQty   Decimal @default(0) @db.Decimal(14, 3)

  purchaseId Int
  purchase   Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variantId  Int
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  returnItems PurchaseReturnItem[]
}

// ---------- Purchase returns ----------
model ReturnType {
  id      Int     @id @default(autoincrement())
  name    String  @unique // Damaged, Wrong item, Excess…
  isActive Boolean @default(true)

  returns PurchaseReturn[]
}

model PurchaseReturn {
  id        Int      @id @default(autoincrement())
  returnNo  String   @unique // PRT-00001
  date      DateTime @default(now())
  total     Decimal  @default(0) @db.Decimal(14, 2)
  refunded  Decimal  @default(0) @db.Decimal(14, 2)
  note      String?
  createdAt DateTime @default(now())

  purchaseId   Int
  purchase     Purchase    @relation(fields: [purchaseId], references: [id])
  supplierId   Int?
  supplier     Contact?    @relation(fields: [supplierId], references: [id])
  returnTypeId Int
  returnType   ReturnType  @relation(fields: [returnTypeId], references: [id])

  items    PurchaseReturnItem[]
  payments Payment[]
}

model PurchaseReturnItem {
  id       Int     @id @default(autoincrement())
  qty      Decimal @db.Decimal(14, 3)
  price    Decimal @db.Decimal(14, 2)
  subtotal Decimal @db.Decimal(14, 2)

  returnId       Int
  purchaseReturn PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  purchaseItemId Int
  purchaseItem   PurchaseItem   @relation(fields: [purchaseItemId], references: [id])
  variantId      Int
  variant        ProductVariant @relation(fields: [variantId], references: [id])
}

// ---------- Sales / POS ----------
model Sale {
  id            Int          @id @default(autoincrement())
  invoiceNo     String       @unique // INV-00001
  date          DateTime     @default(now())
  dueDate       DateTime? // when a credit sale falls due
  channel       SaleChannel  @default(REGULAR)
  itemsCount    Int          @default(0)
  subtotal      Decimal      @default(0) @db.Decimal(14, 2)
  discountType  DiscountType @default(AMOUNT)
  discountValue Decimal      @default(0) @db.Decimal(14, 2)
  discount      Decimal      @default(0) @db.Decimal(14, 2) // resolved amount
  vat           Decimal      @default(0) @db.Decimal(14, 2) // deferred — stays 0 for now
  total         Decimal      @default(0) @db.Decimal(14, 2)
  paid          Decimal      @default(0) @db.Decimal(14, 2)
  due           Decimal      @default(0) @db.Decimal(14, 2)
  status        DocStatus    @default(PAID)
  note          String?
  createdAt     DateTime     @default(now())

  customerId Int?
  customer   Contact? @relation(fields: [customerId], references: [id])
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  soldById   Int?
  soldBy     User?    @relation("SoldBy", fields: [soldById], references: [id])

  items    SaleItem[]
  payments Payment[]
  returns  SaleReturn[]
}

/// A parked cart. Touches no stock and no ledger until it's checked out.
model HeldSale {
  id         Int      @id @default(autoincrement())
  label      String // what the cashier calls it, e.g. "Blue shirt guy"
  cart       Json // the cart lines, as-is
  customerId Int?
  createdAt  DateTime @default(now())

  heldById Int?
  heldBy   User? @relation("HeldBy", fields: [heldById], references: [id])
}

model SaleItem {
  id  Int     @id @default(autoincrement())
  qty Decimal @db.Decimal(14, 3)
  /// What we actually charged per unit — already net of the variant/group discount
  /// and of any wholesale switch (BLUEPRINT §12.7a). Everything downstream (returns,
  /// profit) reads THIS, so `Sale.subtotal` carries only bill-level discounting.
  price Decimal @db.Decimal(14, 2)
  /// The catalogue price, kept so a receipt can show what was saved.
  listPrice   Decimal @default(0) @db.Decimal(14, 2)
  discount    Decimal @default(0) @db.Decimal(14, 2) // (listPrice − price) × qty
  costAtSale  Decimal @default(0) @db.Decimal(14, 2) // for profit/loss
  subtotal    Decimal @db.Decimal(14, 2)
  returnedQty Decimal @default(0) @db.Decimal(14, 3)

  saleId    Int
  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  returnItems SaleReturnItem[]
}

// ---------- Sale returns ----------
model SaleReturn {
  id        Int      @id @default(autoincrement())
  returnNo  String   @unique // SRT-00001
  date      DateTime @default(now())
  total     Decimal  @default(0) @db.Decimal(14, 2)
  refunded  Decimal  @default(0) @db.Decimal(14, 2)
  note      String?
  createdAt DateTime @default(now())

  saleId     Int
  sale       Sale     @relation(fields: [saleId], references: [id])
  customerId Int?
  customer   Contact? @relation(fields: [customerId], references: [id])

  items    SaleReturnItem[]
  payments Payment[]
}

model SaleReturnItem {
  id       Int     @id @default(autoincrement())
  qty      Decimal @db.Decimal(14, 3)
  price    Decimal @db.Decimal(14, 2)
  // The cost the goods left at — they go back on the shelf at that cost, not today's average.
  cost     Decimal @default(0) @db.Decimal(14, 2)
  subtotal Decimal @db.Decimal(14, 2)

  returnId   Int
  saleReturn SaleReturn     @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItemId Int
  saleItem   SaleItem       @relation(fields: [saleItemId], references: [id])
  variantId  Int
  variant    ProductVariant @relation(fields: [variantId], references: [id])
}

// ---------- Accounting ----------
model Account {
  id             Int         @id @default(autoincrement())
  name           String
  type           AccountType @default(CASH)
  bankName       String?
  accountNumber  String?
  openingBalance Decimal     @default(0) @db.Decimal(14, 2)
  balance        Decimal     @default(0) @db.Decimal(14, 2)
  createdAt      DateTime    @default(now())

  payments Payment[]
}

model Payment {
  id        Int              @id @default(autoincrement())
  direction PaymentDirection
  amount    Decimal          @db.Decimal(14, 2)
  method    String? // CASH, MOBILE, CARD, BANK, CHEQUE
  date      DateTime         @default(now())
  note      String?

  accountId        Int?
  account          Account?        @relation(fields: [accountId], references: [id])
  contactId        Int?
  contact          Contact?        @relation(fields: [contactId], references: [id])
  saleId           Int?
  sale             Sale?           @relation(fields: [saleId], references: [id])
  purchaseId       Int?
  purchase         Purchase?       @relation(fields: [purchaseId], references: [id])
  purchaseReturnId Int?
  purchaseReturn   PurchaseReturn? @relation(fields: [purchaseReturnId], references: [id])
  saleReturnId     Int?
  saleReturn       SaleReturn?     @relation(fields: [saleReturnId], references: [id])
}

// ---------- Inventory audit trail ----------
model StockMovement {
  id        Int               @id @default(autoincrement())
  type      StockMovementType
  qty       Decimal           @db.Decimal(14, 3) // + in, - out
  refType   String?
  refId     Int?
  note      String?
  createdAt DateTime          @default(now())

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId])
}
