// MPoS — Retail POS + Inventory (single-store MVP)
// Schema: Phase-1 core. See BLUEPRINT.md for the full data model.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------
enum ContactType {
  CUSTOMER
  SUPPLIER
}

enum ProductType {
  SIMPLE
  VARIABLE
}

enum SaleChannel {
  REGULAR
  WHOLESALE
  ONLINE
}

enum DocStatus {
  PAID
  PARTIAL
  DUE
}

/// How a customer's point balance moved, and what moved it (BLUEPRINT §15.6).
/// `Contact.loyaltyPoints` is only a cache — THIS is the truth.
enum PointEntryType {
  EARN
  REDEEM
  REVERSE
}

/// Which document the till opens after a sale (BLUEPRINT §27.3).
enum PrintDoc {
  RECEIPT
  A4
}

/// Shop-wide settings. Exactly ONE row (id = 1), with typed columns and real
/// defaults rather than a key/value bag of strings (BLUEPRINT §17.1).
/// The loyalty defaults are the reference shop's actual live rule, verified against
/// three of their invoices: floor(bill / 100) × 10 points, each worth 0.10 (§15.1).
model ShopSetting {
  id Int @id @default(1)

  loyaltyEnabled Boolean @default(true)
  /// Earn `earnPoints` for every `earnAmount` on the bill…
  earnAmount     Decimal @default(100) @db.Decimal(14, 2)
  earnPoints     Int     @default(10)
  /// …and if repeating, for EVERY full multiple of it (640 → 6 × 10 = 60 points).
  earnRepeating  Boolean @default(true)
  /// What one point is worth when spent. 0.10 → 100 points = 10.00.
  pointValue     Decimal @default(0.10) @db.Decimal(14, 4)
  /// A balance below this cannot be spent at all.
  minRedeemPoints Int    @default(100)
  /// Points may cover at most this share of a bill, so every sale takes real money.
  maxRedeemPct    Int    @default(50)

  /// Shop-wide low-stock threshold; a product's own `alertQty` overrides it.
  defaultAlertQty Int @default(5)

  /// How sale invoices are numbered (BLUEPRINT §26). The invoice is the only document
  /// a customer holds, so it is the only one whose numbering a shop can set — it has to
  /// line up with the books they are moving off. Next number = max(last + 1, start), so
  /// a duplicate is impossible whatever is typed here.
  invoicePrefix  String @default("INV-")
  invoiceStartNo Int    @default(1)

  /// What prints on the receipt and the invoice (BLUEPRINT §27). All of this was
  /// hard-coded until now.
  showTime           Boolean @default(true)
  showSizeColour     Boolean @default(true)
  /// Off by default: the SKU is our code, and it means nothing to the customer.
  showSku            Boolean @default(false)
  showPaymentDetails Boolean @default(true)
  showInWords        Boolean @default(true)
  /// A4 only — an 80mm till roll has no room for signature lines.
  showSignatures     Boolean @default(true)
  signatureLeft      String  @default("Received by")
  signatureRight     String  @default("Authorised by")
  /// ⚠️ Empty by default, and it must stay that way (§27.2). MPoS used to print
  /// "Goods once sold are exchangeable within 7 days" — a returns promise in the shop's
  /// name that no shop ever made. A policy on a customer's slip is the shop's to write.
  footerNote         String?
  /// Which document opens after a sale is rung up.
  defaultPrint       PrintDoc @default(RECEIPT)

  /// Who the shop IS — printed on every receipt and invoice (BLUEPRINT §20.1).
  /// Without these the receipt is headed with the name of our software, which tells
  /// the customer nothing about the shop they just bought from.
  shopName    String  @default("MPoS")
  shopAddress String?
  shopPhone   String?
  shopEmail   String?
  /// The word the amount-in-words line ends with — "TK Only", "Taka Only".
  currencyWord String @default("TK")
  /// The shop's logo, as a storage key (BLUEPRINT §28). Not a URL: the bytes live on our
  /// own disk and `/api/files/<key>` serves them.
  logoKey     String?

  updatedAt DateTime @updatedAt
}

/// One row per point movement, each pointing at what caused it. Without this,
/// "why do I have 340 points?" is unanswerable (BLUEPRINT §15.6).
model PointEntry {
  id     Int            @id @default(autoincrement())
  /// Signed: + earned, − redeemed. A REVERSE can be either way.
  points Int
  type   PointEntryType
  note   String?
  date   DateTime       @default(now())

  contactId Int
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  saleId       Int?
  sale         Sale?       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleReturnId Int?
  saleReturn   SaleReturn? @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

enum StockMovementType {
  PURCHASE
  SALE
  PURCHASE_RETURN
  SALE_RETURN
  ADJUSTMENT
}

enum AccountType {
  CASH
  BANK
  MOBILE
}

enum PaymentDirection {
  IN
  OUT
}

enum DiscountType {
  AMOUNT
  PERCENT
}

// ---------- Org / Access ----------
model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users     User[]
  products  Product[]
  purchases Purchase[]
  sales     Sale[]
  expenses  Expense[]
  adjustments StockAdjustment[]
  employees   Employee[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions String[] // list of "module.action" keys
  createdAt   DateTime @default(now())

  users User[]
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  username     String   @unique
  email        String?  @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  roleId   Int?
  role     Role?   @relation(fields: [roleId], references: [id])
  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  salesSold Sale[]     @relation("SoldBy")
  salariesPaid SalaryPayment[] @relation("SalaryBy")
  heldSales HeldSale[] @relation("HeldBy")
  expenses  Expense[]  @relation("ExpenseBy")
  adjustments StockAdjustment[] @relation("AdjustmentBy")
}

// ---------- Catalog ----------
model Category {
  id        Int      @id @default(autoincrement())
  name      String
  level     Int      @default(1) // 1=category, 2=sub, 3=child
  createdAt DateTime @default(now())

  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]
}

model Brand {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

// ---------- Variant dimensions ----------

/// A named axis a product can vary along — Size, Fit, Material.
model AttributeCategory {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  createdAt  DateTime    @default(now())
  attributes Attribute[]
  products   Product[]
}

/// A value on that axis — 32, 34, Slim, Cotton.
model Attribute {
  id        Int      @id @default(autoincrement())
  name      String
  sortIndex Int      @default(0)
  createdAt DateTime @default(now())

  attributeCategoryId Int
  attributeCategory   AttributeCategory @relation(fields: [attributeCategoryId], references: [id], onDelete: Cascade)

  /// Which products offer this value (the picker on the product form).
  products Product[]
  /// Which generated variants carry it.
  variants ProductVariant[]

  @@unique([attributeCategoryId, name])
}

/// Colour is its own axis, crossed with the attribute to generate variants.
model Color {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  hex       String? // for a swatch; optional
  sortIndex Int      @default(0)
  createdAt DateTime @default(now())

  products Product[]
  variants ProductVariant[]
}

model Unit {
  id        Int     @id @default(autoincrement())
  name      String
  shortName String?
  /// Whether a fraction of this unit is a real thing (BLUEPRINT §21).
  ///
  /// A piece cannot be cut in half; 2.5 metres of fabric is ordinary. Without
  /// this, "Piece" and "Metre" are the same to the app, and half a shirt can
  /// land on the books and never leave — the till will only sell whole ones.
  ///
  /// Defaults to FALSE: whole is both the common case and the safe one.
  allowDecimal Boolean @default(false)

  products Product[]
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  code        String? // a second identifier alongside the variants' SKUs
  description String?
  type        ProductType @default(SIMPLE)
  /// An uploaded photo, as a storage key (BLUEPRINT §28). This replaced a pasted image
  /// URL that nobody could use without hosting the picture somewhere else first — and
  /// which never held a single value.
  imageKey    String?
  isActive    Boolean     @default(true)
  sortIndex   Int         @default(0)
  createdAt   DateTime    @default(now())

  /// Low-stock threshold for THIS product. Null falls back to the global default.
  alertQty Decimal? @db.Decimal(14, 3)
  /// A price floor. Checkout refuses to sell any variant below it (BLUEPRINT §12.7).
  minSalePrice Decimal? @db.Decimal(14, 2)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
  brandId    Int?
  brand      Brand?    @relation(fields: [brandId], references: [id])
  unitId     Int?
  unit       Unit?     @relation(fields: [unitId], references: [id])
  branchId   Int?
  branch     Branch?   @relation(fields: [branchId], references: [id])

  /// The axis this product varies along, and the values picked on it — kept so the
  /// variant grid can be regenerated on edit without re-picking everything.
  attributeCategoryId Int?
  attributeCategory   AttributeCategory? @relation(fields: [attributeCategoryId], references: [id])
  attributes          Attribute[]
  colors              Color[]

  variants ProductVariant[]
}

model ProductVariant {
  id                Int      @id @default(autoincrement())
  sku               String   @unique
  barcode           String?  @unique // auto EAN-13 (in-store `20` range), editable
  label             String? // e.g. "Red / L"
  attributes        Json? // { color: "Red", size: "L" }
  sortIndex         Int      @default(0)
  purchasePrice     Decimal  @default(0) @db.Decimal(14, 2) // weighted-average cost
  lastPurchasePrice Decimal? @db.Decimal(14, 2) // price on the most recent purchase
  sellingPrice      Decimal  @default(0) @db.Decimal(14, 2)
  stockQty          Decimal  @default(0) @db.Decimal(14, 3)
  createdAt         DateTime @default(now())

  /// Sell this many or more on one line and the price switches to wholesale.
  wholesalePrice Decimal? @db.Decimal(14, 2)
  wholesaleQty   Decimal? @db.Decimal(14, 3)

  /// A standing discount on this variant. Competes with the customer group's rate —
  /// the bigger of the two wins, they never stack (BLUEPRINT §12.7a).
  discountType  DiscountType @default(AMOUNT)
  discountValue Decimal      @default(0) @db.Decimal(14, 2)

  /// What this variant *is*, on each axis — set by the variant generator.
  attributeId Int?
  attribute   Attribute? @relation(fields: [attributeId], references: [id])
  colorId     Int?
  color       Color?     @relation(fields: [colorId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  purchaseItems       PurchaseItem[]
  saleItems           SaleItem[]
  stockMovements      StockMovement[]
  purchaseReturnItems PurchaseReturnItem[]
  saleReturnItems     SaleReturnItem[]
  adjustmentItems     StockAdjustmentItem[]

  @@index([productId])
}

// ---------- Contacts (customers & suppliers) ----------
model CustomerGroup {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  discount  Decimal  @default(0) @db.Decimal(5, 2) // default % off this customer's sales
  createdAt DateTime @default(now())

  customers Contact[]
}

model Contact {
  id             Int         @id @default(autoincrement())
  type           ContactType
  name           String
  businessName   String?
  phone          String?
  email          String?
  address        String?
  note           String?
  openingBalance Decimal     @default(0) @db.Decimal(14, 2)
  // For a supplier: + = we owe them (payable). For a customer: + = they owe us.
  dueBalance     Decimal     @default(0) @db.Decimal(14, 2)
  loyaltyPoints  Int         @default(0)
  isActive       Boolean     @default(true)
  isWalkIn       Boolean     @default(false) // the POS default customer; not deletable
  createdAt      DateTime    @default(now())

  customerGroupId Int?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id])

  purchases       Purchase[]
  sales           Sale[]
  allocations     DueAllocation[]
  payments        Payment[]
  purchaseReturns PurchaseReturn[]
  saleReturns     SaleReturn[]
  exchanges       Exchange[]
  pointEntries    PointEntry[]

  @@index([type])
}

// ---------- Purchasing ----------
model Purchase {
  id                Int          @id @default(autoincrement())
  purchaseNo        String       @unique // our own sequence, e.g. PUR-00001
  supplierInvoiceNo String? // the supplier's invoice number — may repeat
  date              DateTime     @default(now())
  dueDate           DateTime?
  reference         String?
  note              String?
  subtotal          Decimal      @default(0) @db.Decimal(14, 2)
  discountType      DiscountType @default(AMOUNT)
  discountValue     Decimal      @default(0) @db.Decimal(14, 2)
  discount          Decimal      @default(0) @db.Decimal(14, 2) // resolved amount
  total             Decimal      @default(0) @db.Decimal(14, 2)
  paid              Decimal      @default(0) @db.Decimal(14, 2)
  due               Decimal      @default(0) @db.Decimal(14, 2)
  status            DocStatus    @default(DUE)
  createdAt         DateTime     @default(now())

  supplierId Int?
  supplier   Contact? @relation(fields: [supplierId], references: [id])
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id])

  items    PurchaseItem[]
  payments Payment[]
  returns  PurchaseReturn[]
}

model PurchaseItem {
  id            Int     @id @default(autoincrement())
  qty           Decimal @db.Decimal(14, 3)
  purchasePrice Decimal @db.Decimal(14, 2)
  subtotal      Decimal @db.Decimal(14, 2)
  returnedQty   Decimal @default(0) @db.Decimal(14, 3)

  purchaseId Int
  purchase   Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variantId  Int
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  returnItems PurchaseReturnItem[]
}

// ---------- Purchase returns ----------
model ReturnType {
  id      Int     @id @default(autoincrement())
  name    String  @unique // Damaged, Wrong item, Excess…
  isActive Boolean @default(true)

  returns PurchaseReturn[]
}

model PurchaseReturn {
  id        Int      @id @default(autoincrement())
  returnNo  String   @unique // PRT-00001
  date      DateTime @default(now())
  total     Decimal  @default(0) @db.Decimal(14, 2)
  refunded  Decimal  @default(0) @db.Decimal(14, 2)
  note      String?
  createdAt DateTime @default(now())

  purchaseId   Int
  purchase     Purchase    @relation(fields: [purchaseId], references: [id])
  supplierId   Int?
  supplier     Contact?    @relation(fields: [supplierId], references: [id])
  returnTypeId Int
  returnType   ReturnType  @relation(fields: [returnTypeId], references: [id])

  items    PurchaseReturnItem[]
  payments Payment[]
}

model PurchaseReturnItem {
  id       Int     @id @default(autoincrement())
  qty      Decimal @db.Decimal(14, 3)
  price    Decimal @db.Decimal(14, 2)
  subtotal Decimal @db.Decimal(14, 2)

  returnId       Int
  purchaseReturn PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  purchaseItemId Int
  purchaseItem   PurchaseItem   @relation(fields: [purchaseItemId], references: [id])
  variantId      Int
  variant        ProductVariant @relation(fields: [variantId], references: [id])
}

// ---------- Sales / POS ----------
model Sale {
  id            Int          @id @default(autoincrement())
  invoiceNo     String       @unique // INV-00001
  date          DateTime     @default(now())
  dueDate       DateTime? // when a credit sale falls due
  channel       SaleChannel  @default(REGULAR)
  itemsCount    Int          @default(0)
  subtotal      Decimal      @default(0) @db.Decimal(14, 2)
  discountType  DiscountType @default(AMOUNT)
  discountValue Decimal      @default(0) @db.Decimal(14, 2)
  discount      Decimal      @default(0) @db.Decimal(14, 2) // resolved amount
  vat           Decimal      @default(0) @db.Decimal(14, 2) // deferred — stays 0 for now
  total         Decimal      @default(0) @db.Decimal(14, 2)
  paid          Decimal      @default(0) @db.Decimal(14, 2)
  /// Goods handed back against this invoice, settled as a credit (BLUEPRINT §22.4).
  /// Kept apart from `paid` because the customer never paid this money — so an
  /// invoice always reads `total = paid + credited + due`: money in, goods back,
  /// still owed.
  credited      Decimal      @default(0) @db.Decimal(14, 2)
  due           Decimal      @default(0) @db.Decimal(14, 2)
  status        DocStatus    @default(PAID)
  note          String?
  /// Loyalty (BLUEPRINT §15). Earned on what the customer actually paid; redeemed
  /// points are settled as a `POINTS` payment, not as a discount on the line.
  pointsEarned   Int         @default(0)
  pointsRedeemed Int         @default(0)
  /// Cash handed over at the till. Without it, a REPRINTED receipt can never show
  /// what was tendered or what change was given (§20.3) — and a reprint that
  /// disagrees with the slip in the customer's hand is worse than no reprint.
  tendered      Decimal?     @db.Decimal(14, 2)
  /// Unguessable key for the public invoice link (§20.5). Null until someone
  /// shares it, and settable back to null to revoke — a shared invoice carries the
  /// customer's name, phone and purchase, so it must be revocable.
  publicToken   String?      @unique
  createdAt     DateTime     @default(now())

  customerId Int?
  customer   Contact? @relation(fields: [customerId], references: [id])
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  soldById   Int?
  soldBy     User?    @relation("SoldBy", fields: [soldById], references: [id])

  items       SaleItem[]
  payments    Payment[]
  returns     SaleReturn[]
  points      PointEntry[]
  expenses    Expense[]
  allocations DueAllocation[]

  exchangedFrom Exchange[] @relation("ExchangeFrom")
  exchangedTo   Exchange?  @relation("ExchangeTo")
}

/// A parked cart. Touches no stock and no ledger until it's checked out.
model HeldSale {
  id         Int      @id @default(autoincrement())
  label      String // what the cashier calls it, e.g. "Blue shirt guy"
  cart       Json // the cart lines, as-is
  customerId Int?
  createdAt  DateTime @default(now())

  heldById Int?
  heldBy   User? @relation("HeldBy", fields: [heldById], references: [id])
}

model SaleItem {
  id  Int     @id @default(autoincrement())
  qty Decimal @db.Decimal(14, 3)
  /// What we actually charged per unit — already net of the variant/group discount
  /// and of any wholesale switch (BLUEPRINT §12.7a). Everything downstream (returns,
  /// profit) reads THIS, so `Sale.subtotal` carries only bill-level discounting.
  price Decimal @db.Decimal(14, 2)
  /// The catalogue price, kept so a receipt can show what was saved.
  listPrice   Decimal @default(0) @db.Decimal(14, 2)
  discount    Decimal @default(0) @db.Decimal(14, 2) // (listPrice − price) × qty
  costAtSale  Decimal @default(0) @db.Decimal(14, 2) // for profit/loss
  subtotal    Decimal @db.Decimal(14, 2)
  returnedQty Decimal @default(0) @db.Decimal(14, 3)
  /// A free issue / QC write-off (BLUEPRINT §16): the goods left at 0.00 on purpose.
  /// Recorded as a fact rather than inferred from `price = 0`, so a write-off can
  /// never be mistaken for a mispriced line. Requires `sales.free_issue` + a remark.
  isFree      Boolean @default(false)

  saleId    Int
  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  returnItems SaleReturnItem[]
}

// ---------- Sale returns ----------
model SaleReturn {
  id        Int      @id @default(autoincrement())
  returnNo  String   @unique // SRT-00001
  date      DateTime @default(now())
  /// What the returned goods were worth, at what the customer actually paid (§10.1a).
  total     Decimal  @default(0) @db.Decimal(14, 2)
  /// The part of `total` that must be settled in MONEY — i.e. `total` less the value
  /// of any points handed back (§15.5). Stored rather than recomputed, so undoing this
  /// return stays exact even if the point value is edited in Settings afterwards.
  moneyCredit Decimal @default(0) @db.Decimal(14, 2)
  refunded  Decimal  @default(0) @db.Decimal(14, 2)
  note      String?
  /// Points clawed back with the goods (BLUEPRINT §15.5). Negative of what was
  /// earned, in proportion to what was credited. Points the customer *spent* on
  /// the original sale come back to them and are recorded as their own entry.
  pointsReversed Int  @default(0)
  createdAt DateTime @default(now())
  /// Which invoices this credit settled (BLUEPRINT §22.4).
  allocations DueAllocation[]

  saleId     Int
  sale       Sale     @relation(fields: [saleId], references: [id])
  customerId Int?
  customer   Contact? @relation(fields: [customerId], references: [id])

  items    SaleReturnItem[]
  payments Payment[]
  points   PointEntry[]
  expenses Expense[]
  exchange Exchange?
}

/// A swap at the counter: goods come back off one invoice and go out on a new one.
///
/// An exchange is not its own kind of document — it is a SaleReturn and a Sale settled
/// as one transaction (BLUEPRINT §14). This row is the link between them, and it is what
/// makes "which invoice replaced which" answerable.
model Exchange {
  id         Int      @id @default(autoincrement())
  exchangeNo String   @unique // EXC-00001
  date       DateTime @default(now())
  /// The value of the goods handed back, at what the customer actually paid for them.
  credit     Decimal  @default(0) @db.Decimal(14, 2)
  createdAt  DateTime @default(now())

  fromSaleId   Int
  fromSale     Sale       @relation("ExchangeFrom", fields: [fromSaleId], references: [id])
  toSaleId     Int        @unique
  toSale       Sale       @relation("ExchangeTo", fields: [toSaleId], references: [id])
  saleReturnId Int        @unique
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id])
  customerId   Int?
  customer     Contact?   @relation(fields: [customerId], references: [id])
}

model SaleReturnItem {
  id       Int     @id @default(autoincrement())
  qty      Decimal @db.Decimal(14, 3)
  price    Decimal @db.Decimal(14, 2)
  // The cost the goods left at — they go back on the shelf at that cost, not today's average.
  cost     Decimal @default(0) @db.Decimal(14, 2)
  subtotal Decimal @db.Decimal(14, 2)

  returnId   Int
  saleReturn SaleReturn     @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItemId Int
  saleItem   SaleItem       @relation(fields: [saleItemId], references: [id])
  variantId  Int
  variant    ProductVariant @relation(fields: [variantId], references: [id])
}

// ---------- Accounting ----------
model Account {
  id             Int         @id @default(autoincrement())
  name           String
  type           AccountType @default(CASH)
  bankName       String?
  accountNumber  String?
  openingBalance Decimal     @default(0) @db.Decimal(14, 2)
  balance        Decimal     @default(0) @db.Decimal(14, 2)
  createdAt      DateTime    @default(now())

  payments Payment[]
  expenses Expense[]
  salaries SalaryPayment[]

  transfersOut AccountTransfer[] @relation("TransferFrom")
  transfersIn  AccountTransfer[] @relation("TransferTo")
}

model Payment {
  id        Int              @id @default(autoincrement())
  direction PaymentDirection
  amount    Decimal          @db.Decimal(14, 2)
  method    String? // CASH, MOBILE, CARD, BANK, CHEQUE
  date      DateTime         @default(now())
  note      String?

  accountId        Int?
  account          Account?        @relation(fields: [accountId], references: [id])
  contactId        Int?
  contact          Contact?        @relation(fields: [contactId], references: [id])
  saleId           Int?
  sale             Sale?           @relation(fields: [saleId], references: [id])
  purchaseId       Int?
  purchase         Purchase?       @relation(fields: [purchaseId], references: [id])
  purchaseReturnId Int?
  purchaseReturn   PurchaseReturn? @relation(fields: [purchaseReturnId], references: [id])
  saleReturnId     Int?
  saleReturn       SaleReturn?     @relation(fields: [saleReturnId], references: [id])
  expenseId        Int?
  expense          Expense?        @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  /// The two legs of a transfer point at it, so neither can be orphaned (§23.3).
  transferId       Int?
  transfer         AccountTransfer? @relation(fields: [transferId], references: [id], onDelete: Cascade)

  /// Which invoices this payment settled (BLUEPRINT §22.4).
  allocations DueAllocation[]
}

// ---------- Stock adjustments (BLUEPRINT §19) ----------

/// Why stock moved without being bought, sold or returned — Damage, Theft, Miscount.
/// The shop names its own; we seed none.
model AdjustmentType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  adjustments StockAdjustment[]
}

/// A stock correction: what was counted, against what we thought was there.
///
/// Lines carry a **counted** quantity, never a signed delta (§19.7) — so the sign can
/// never be typed backwards, and a correction up and a write-off down use one field.
model StockAdjustment {
  id           Int      @id @default(autoincrement())
  adjustmentNo String   @unique // ADJ-00001
  date         DateTime @default(now())
  remark       String?
  /// Value of what went missing, at weighted-average cost. Negative = goods found.
  /// Stored rather than recomputed: the average moves, but what this cost us does not.
  lossValue    Decimal  @default(0) @db.Decimal(14, 2)
  createdAt    DateTime @default(now())

  adjustmentTypeId Int
  adjustmentType   AdjustmentType @relation(fields: [adjustmentTypeId], references: [id])

  branchId    Int?
  branch      Branch? @relation(fields: [branchId], references: [id])
  createdById Int?
  createdBy   User?   @relation("AdjustmentBy", fields: [createdById], references: [id])

  items    StockAdjustmentItem[]
  expenses Expense[]

  @@index([date])
}

model StockAdjustmentItem {
  id Int @id @default(autoincrement())
  /// What the system thought was there when the count was taken.
  stockQty   Decimal @db.Decimal(14, 3)
  /// What was actually on the shelf.
  countedQty Decimal @db.Decimal(14, 3)
  /// counted − onHand. Negative = goods lost. Derived, never typed.
  delta      Decimal @db.Decimal(14, 3)
  /// The weighted-average cost at the moment of the count — what the loss really cost.
  cost       Decimal @db.Decimal(14, 2)

  adjustmentId Int
  adjustment   StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  variantId    Int
  variant      ProductVariant  @relation(fields: [variantId], references: [id])

  @@index([adjustmentId])
}

// ---------- Expenses (BLUEPRINT §18) ----------

/// What an expense is *for* — Space Rent, Electricity, Salary. Just a name, like a
/// Brand or a Unit. The shop names its own; we seed none but the system one.
model ExpenseType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  /// Posted automatically, never by hand — "Loyalty points" (§18.8). Cannot be
  /// deleted or renamed, because a sale points at it.
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  expenses Expense[]
}

/// Money the shop spends. Rent, wages, electricity — the block the P&L was missing,
/// and the difference between gross profit and knowing whether you made any money.
model Expense {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now()) // may be back-dated: the shop books at month-end (§18.8)
  amount    Decimal  @db.Decimal(14, 2) // negative = a contra entry reversing an earlier one
  note      String?
  createdAt DateTime @default(now())

  expenseTypeId Int
  expenseType   ExpenseType @relation(fields: [expenseTypeId], references: [id])

  /// Which account the money left. **Null means no cash moved** — the loyalty-points
  /// expense (§18.8) makes the scheme's cost visible without pretending it was paid,
  /// exactly like the POINTS payment (§15.4) and the EXCHANGE credit (§14).
  accountId Int?
  account   Account? @relation(fields: [accountId], references: [id])

  /// Set only on an automatic expense: the sale whose points redemption caused it.
  /// Its presence is what makes an expense read-only by hand — it is owned by the sale.
  saleId Int?
  sale   Sale? @relation(fields: [saleId], references: [id], onDelete: Cascade)

  /// Set on the contra entry a return posts. Undo the return and the contra goes
  /// with it — otherwise the cost of the scheme would stay clawed back after the
  /// points had been taken away from the customer again.
  saleReturnId Int?
  saleReturn   SaleReturn? @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  /// Set on the "Stock loss" expense an adjustment posts (§19.6). Delete the
  /// adjustment and the loss it booked goes with it.
  stockAdjustmentId Int?
  stockAdjustment   StockAdjustment? @relation(fields: [stockAdjustmentId], references: [id], onDelete: Cascade)

  /// Set on the "Salary" expense a wage payment posts (§24.2). Wages are an ordinary
  /// expense — that is what puts them in the P&L without a second code path.
  salaryPaymentId Int?
  salaryPayment   SalaryPayment? @relation(fields: [salaryPaymentId], references: [id], onDelete: Cascade)

  branchId    Int?
  branch      Branch? @relation(fields: [branchId], references: [id])
  createdById Int?
  createdBy   User?   @relation("ExpenseBy", fields: [createdById], references: [id])

  payments Payment[]

  @@index([date])
  @@index([expenseTypeId])
}

// ---------- Inventory audit trail ----------
model StockMovement {
  id        Int               @id @default(autoincrement())
  type      StockMovementType
  qty       Decimal           @db.Decimal(14, 3) // + in, - out
  refType   String?
  refId     Int?
  note      String?
  createdAt DateTime          @default(now())

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId])
}

/// What settled which invoice (BLUEPRINT §22.4).
///
/// `Sale.due` is a cache; this is the ledger behind it. Every payment a customer
/// makes against their account, and every credit for goods they hand back, lands
/// on one or more invoices — oldest first — and each landing is a row here.
///
/// It exists so a deletion can be reversed *exactly*. Re-deriving which invoices a
/// deleted payment had settled is guesswork the moment a second payment has been
/// made; reading back the rows it wrote is not. Same discipline as `PointEntry`
/// behind `Contact.loyaltyPoints` (§15): a balance nobody can explain is a balance
/// nobody can trust.
model DueAllocation {
  id     Int            @id @default(autoincrement())
  kind   AllocationKind
  /// Always positive — the direction is the `kind`, never the sign.
  amount Decimal        @db.Decimal(14, 2)
  date   DateTime       @default(now())

  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  contactId Int
  contact   Contact @relation(fields: [contactId], references: [id])

  /// Exactly one of these names the movement that caused it.
  paymentId    Int?
  payment      Payment?    @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  saleReturnId Int?
  saleReturn   SaleReturn? @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([contactId])
}

enum AllocationKind {
  /// Money the customer handed over after the sale.
  PAYMENT
  /// Goods the customer handed back. No money moved.
  CREDIT
}

/// Money moved between two of the shop's own accounts (BLUEPRINT §23.3).
///
/// Written as TWO `Payment` rows — out of one account, in to the other — tied
/// together here. Never one row touching two accounts: that is how a balance goes
/// missing, and it makes an exact reversal impossible.
model AccountTransfer {
  id     Int      @id @default(autoincrement())
  amount Decimal  @db.Decimal(14, 2)
  date   DateTime @default(now())
  note   String?

  fromAccountId Int
  fromAccount   Account @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccountId   Int
  toAccount     Account @relation("TransferTo", fields: [toAccountId], references: [id])

  /// The two legs. They cascade away with the transfer.
  payments Payment[]

  createdAt DateTime @default(now())
}

// ---------- Employees & salary (BLUEPRINT §24) ----------

model Employee {
  id            Int      @id @default(autoincrement())
  name          String
  designation   String
  phone         String
  address       String?
  email         String?
  /// National ID. Optional in their form too.
  nid           String?
  joiningDate   DateTime
  /// What they are owed each month. A payment may be more or less than it.
  monthlySalary Decimal  @db.Decimal(14, 2)
  /// Staff are retired, not deleted — one of the reference shop's four is inactive.
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  payments SalaryPayment[]
}

/// Wages paid to one employee for one month (BLUEPRINT §24.3).
///
/// ONE document covers what the reference app splits into "Pay Salary" and "Pay
/// Advance": an advance is just a payment stamped with a month that has not
/// arrived yet, and a partial payment is just a smaller amount. The month's DUE is
/// derived (`monthlySalary − Σ paid for that month`), never stored — a stored due
/// is a second number that can disagree with the payments behind it.
model SalaryPayment {
  id     Int      @id @default(autoincrement())
  /// The month the wages are FOR — not when they were handed over.
  month  Int // 1–12
  year   Int
  amount Decimal  @db.Decimal(14, 2)
  /// When the money actually left. Back-datable: the shop pays on the last day.
  date   DateTime @default(now())
  note   String?
  createdAt DateTime @default(now())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  /// Which account it left. Required in practice — a wage that moves no money is
  /// not a wage — but nullable so the FK matches every other document.
  accountId Int?
  account   Account? @relation(fields: [accountId], references: [id])

  paidById Int?
  paidBy   User? @relation("SalaryBy", fields: [paidById], references: [id])

  /// The Salary expense this posted. It cascades away when the payment is deleted.
  expenses Expense[]

  @@index([employeeId])
  @@index([year, month])
}
